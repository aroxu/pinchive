# Copy to .env and adjust.

# Where downloads, sqlite db, and cookies live (inside container).
PINCHIVE_DATA_DIR=/data

# Redis connection for the arq task queue.
PINCHIVE_REDIS_URL=redis://redis:6379

# Max concurrent gallery-dl download jobs.
PINCHIVE_MAX_CONCURRENCY=2

# No overall board timeout. Instead, if a single pin download stalls (no data)
# for this many seconds, gallery-dl aborts just that file and continues to the
# next pin. Default 600s (10 min).
PINCHIVE_PIN_STALL_TIMEOUT=600

# Credential keep-alive: periodically re-hit Pinterest and persist the rotated
# session cookie so a registered credential stays alive without re-pasting.
# Runs every N hours (6 -> 00,06,12,18). Set to 0 to run once/day at REFRESH_HOUR.
# Keep it modest — hammering Pinterest looks like a bot.
PINCHIVE_REFRESH_EVERY_HOURS=6
PINCHIVE_REFRESH_HOUR=4
PINCHIVE_REFRESH_MINUTE=0

# --- Which image to run ---
# Leave unset to build locally (tagged pinchive:latest). To pull a published
# variant instead: the slim default or the chromium-bundled one.
#   PINCHIVE_IMAGE=ghcr.io/aroxu/pinchive:latest       # slim
#   PINCHIVE_IMAGE=ghcr.io/aroxu/pinchive:playwright   # + chromium fallback
# PINCHIVE_IMAGE=ghcr.io/aroxu/pinchive:latest

# --- Optional Playwright re-login fallback (for genuinely dead sessions) ---
# Two switches, both default off. See docs/credential-refresh.md.
#   INSTALL_PLAYWRIGHT           build-time: bake chromium into a LOCAL build
#                                (ignored when pulling a published image)
#   PINCHIVE_USE_PLAYWRIGHT_FALLBACK  runtime: actually attempt re-login on death
#                                (only works on the :playwright image / local
#                                 build with INSTALL_PLAYWRIGHT=true)
INSTALL_PLAYWRIGHT=false
PINCHIVE_USE_PLAYWRIGHT_FALLBACK=false

# gallery-dl sleep between requests (seconds) to stay polite / avoid rate limits.
PINCHIVE_DL_SLEEP=0.8

# Automatic board re-sync: periodically re-download boards to pick up new pins
# (cheap — the per-board archive only fetches new pins). Runs every N hours;
# set to 0 to disable. Boards can opt out individually in the UI (auto-sync).
PINCHIVE_RESYNC_EVERY_HOURS=24
PINCHIVE_RESYNC_MINUTE=30

# UI page sizes.
PINCHIVE_PER_PAGE_BOARDS=24
PINCHIVE_PER_PAGE_PINS=60
PINCHIVE_PER_PAGE_DUPES=20
