# Copy to .env and adjust.

# Where downloads, sqlite db, and cookies live (inside container).
PINCHIVE_DATA_DIR=/data

# Redis connection for the arq task queue.
PINCHIVE_REDIS_URL=redis://redis:6379

# Max concurrent gallery-dl download jobs.
PINCHIVE_MAX_CONCURRENCY=2

# Credential keep-alive: periodically re-hit Pinterest and persist the rotated
# session cookie so a registered credential stays alive without re-pasting.
# Runs every N hours (6 -> 00,06,12,18). Set to 0 to run once/day at REFRESH_HOUR.
# Keep it modest — hammering Pinterest looks like a bot.
PINCHIVE_REFRESH_EVERY_HOURS=6
PINCHIVE_REFRESH_HOUR=4
PINCHIVE_REFRESH_MINUTE=0

# Optional: enable Playwright auto re-login (requires `refresh` extra + browsers).
PINCHIVE_ENABLE_AUTO_REFRESH=false

# gallery-dl sleep between requests (seconds) to stay polite / avoid rate limits.
PINCHIVE_DL_SLEEP=0.8
